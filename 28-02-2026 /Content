<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MSP430 GPIO — Lab Session 1 | GitHub README</title>
    <style>
        /* GitHub Light & Dark friendly — respects system preference via CSS variables */
        :root {
            --color-text-primary: #1f2328;
            --color-text-secondary: #656d76;
            --color-background-primary: #ffffff;
            --color-background-secondary: #f6f8fa;
            --color-border-tertiary: #d0d7de;
            /* Badge / accent colors */
            --badge-output-bg: #E1F5EE;
            --badge-output-text: #0F6E56;
            --badge-input-bg: #E6F1FB;
            --badge-input-text: #185FA5;
            --badge-pull-bg: #FAEEDA;
            --badge-pull-text: #854F0B;
            --badge-multi-bg: #EEEDFE;
            --badge-multi-text: #3C3489;
            --badge-mixed-bg: #FCEBEB;
            --badge-mixed-text: #A32D2D;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --color-text-primary: #e6edf3;
                --color-text-secondary: #8b949e;
                --color-background-primary: #0d1117;
                --color-background-secondary: #161b22;
                --color-border-tertiary: #30363d;
                /* slightly adjusted dark mode badges */
                --badge-output-bg: #1A3A32;
                --badge-output-text: #7EE4C0;
                --badge-input-bg: #1C2D42;
                --badge-input-text: #89C2FF;
                --badge-pull-bg: #3A2E1A;
                --badge-pull-text: #F5C26B;
                --badge-multi-bg: #2A2848;
                --badge-multi-text: #B6ACFF;
                --badge-mixed-bg: #3D2525;
                --badge-mixed-text: #F9A8A8;
            }
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, 'Roboto', 'Fira Code', monospace;
            background-color: var(--color-background-primary);
            padding: 2rem 1.5rem;
            line-height: 1.5;
        }

        /* Main container mimics original lab style */
        .readme-container {
            font-family: 'Segoe UI', 'SF Mono', 'JetBrains Mono', monospace;
            max-width: 880px;
            margin: 0 auto;
            background: var(--color-background-primary);
            border-radius: 16px;
        }

        /* project header */
        .header-border {
            border-left: 3px solid #1D9E75;
            padding-left: 1rem;
            margin-bottom: 2rem;
        }

        .date {
            font-size: 11px;
            color: var(--color-text-secondary);
            margin-bottom: 4px;
            letter-spacing: 0.02em;
        }

        .main-title {
            font-size: 22px;
            font-weight: 500;
            color: var(--color-text-primary);
            line-height: 1.3;
        }

        .subhead {
            font-size: 13px;
            color: var(--color-text-secondary);
            margin-top: 6px;
        }

        /* stats grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--color-background-secondary);
            border-radius: 12px;
            padding: 12px 14px;
            border: 0.5px solid var(--color-border-tertiary);
        }

        .stat-label {
            font-size: 11px;
            color: var(--color-text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.04em;
            margin-bottom: 6px;
        }

        .stat-value {
            font-size: 15px;
            font-weight: 500;
            color: var(--color-text-primary);
        }

        /* section header */
        .section-header {
            font-size: 12px;
            color: var(--color-text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 1rem;
            margin-top: 0.5rem;
        }

        /* project list */
        .project-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 2rem;
        }

        .project-row {
            display: grid;
            grid-template-columns: 32px 88px 1fr auto;
            align-items: center;
            gap: 12px;
            background: var(--color-background-primary);
            border: 0.5px solid var(--color-border-tertiary);
            border-radius: 10px;
            padding: 10px 14px;
            transition: background 0.1s ease;
        }

        .project-num {
            font-size: 12px;
            color: var(--color-text-secondary);
            font-weight: 450;
        }

        .badge {
            font-size: 10.5px;
            font-weight: 500;
            padding: 4px 8px;
            border-radius: 20px;
            text-align: center;
            display: inline-block;
            width: fit-content;
            letter-spacing: 0.01em;
        }

        .badge-output {
            background: var(--badge-output-bg);
            color: var(--badge-output-text);
        }

        .badge-input {
            background: var(--badge-input-bg);
            color: var(--badge-input-text);
        }

        .badge-pull {
            background: var(--badge-pull-bg);
            color: var(--badge-pull-text);
        }

        .badge-multi {
            background: var(--badge-multi-bg);
            color: var(--badge-multi-text);
        }

        .badge-mixed {
            background: var(--badge-mixed-bg);
            color: var(--badge-mixed-text);
        }

        .project-desc {
            font-size: 13px;
            color: var(--color-text-primary);
            font-weight: 450;
            line-height: 1.4;
        }

        .project-pins {
            font-size: 11px;
            color: var(--color-text-secondary);
            font-family: monospace;
            background: var(--color-background-secondary);
            padding: 3px 8px;
            border-radius: 24px;
            white-space: nowrap;
        }

        /* keywords container */
        .keywords-section {
            margin-top: 1.5rem;
            border-top: 0.5px solid var(--color-border-tertiary);
            padding-top: 1.5rem;
        }

        .keywords-title {
            font-size: 12px;
            color: var(--color-text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 12px;
        }

        .keywords-flex {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .keyword {
            font-size: 12px;
            background: var(--color-background-secondary);
            color: var(--color-text-secondary);
            padding: 4px 12px;
            border-radius: 24px;
            border: 0.5px solid var(--color-border-tertiary);
            font-family: monospace;
        }

        /* small extra spacing for GitHub looks */
        .footer-note {
            margin-top: 2rem;
            font-size: 11px;
            color: var(--color-text-secondary);
            text-align: center;
            border-top: 0.5px solid var(--color-border-tertiary);
            padding-top: 1.2rem;
        }

        @media (max-width: 620px) {
            .project-row {
                grid-template-columns: 28px 70px 1fr auto;
                gap: 8px;
            }
            .project-desc {
                font-size: 12px;
            }
            .badge {
                font-size: 9px;
                padding: 3px 6px;
            }
            .project-pins {
                font-size: 9px;
                white-space: normal;
                word-break: keep-all;
            }
        }
    </style>
</head>
<body>
<div class="readme-container">
    <!-- header area: date, title, sub -->
    <div class="header-border">
        <div class="date">28-02-2026</div>
        <div class="main-title">MSP430 GPIO — Lab Session 1</div>
        <div class="subhead">Texas Instruments MSP430 · Microprocessor Applications · Hands-on Training</div>
    </div>

    <!-- microcontroller + IDE stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">microcontroller</div>
            <div class="stat-value">MSP430G2553</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">IDE</div>
            <div class="stat-value">Code Composer Studio</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">projects</div>
            <div class="stat-value">9 completed</div>
        </div>
    </div>

    <!-- Project Log section -->
    <div class="section-header">📋 Project Log</div>
    <div class="project-list">
        <!-- 01 - Output -->
        <div class="project-row">
            <span class="project-num">01</span>
            <span class="badge badge-output">Output</span>
            <span class="project-desc">Hello — P1.0 LED1 basic output check</span>
            <span class="project-pins">P1.0</span>
        </div>
        <!-- 02 - Output -->
        <div class="project-row">
            <span class="project-num">02</span>
            <span class="badge badge-output">Output</span>
            <span class="project-desc">LED — Alternating blink with delay cycles</span>
            <span class="project-pins">P1.0 P1.6</span>
        </div>
        <!-- 03 - Output -->
        <div class="project-row">
            <span class="project-num">03</span>
            <span class="badge badge-output">Output</span>
            <span class="project-desc">Digital output — P1.4 enable with while loop delay</span>
            <span class="project-pins">P1.0 P1.4 P1.6</span>
        </div>
        <!-- 04 - Output -->
        <div class="project-row">
            <span class="project-num">04</span>
            <span class="badge badge-output">Output</span>
            <span class="project-desc">Digital output — Multi-port output with P2.3</span>
            <span class="project-pins">P1.0 P1.4 P2.3</span>
        </div>
        <!-- 05 - Input -->
        <div class="project-row">
            <span class="project-num">05</span>
            <span class="badge badge-input">Input</span>
            <span class="project-desc">Floating input — if-else LED control via P1.5</span>
            <span class="project-pins">P1.5 → P1.0 P1.6</span>
        </div>
        <!-- 06 - Pull-up/dn -->
        <div class="project-row">
            <span class="project-num">06</span>
            <span class="badge badge-pull">Pull-up/dn</span>
            <span class="project-desc">Floating fix — P1REN resistor prevents float on P1.1</span>
            <span class="project-pins">P1.1 → P1.0 P1.6</span>
        </div>
        <!-- 07 - Multi if-else -->
        <div class="project-row">
            <span class="project-num">07</span>
            <span class="badge badge-multi">Multi if-else</span>
            <span class="project-desc">Multi-input — P2.1 P2.2 with enabled resistors</span>
            <span class="project-pins">P2.1 P2.2 → P1.0 P1.6</span>
        </div>
        <!-- 08 - Switch-case -->
        <div class="project-row">
            <span class="project-num">08</span>
            <span class="badge badge-multi">Switch-case</span>
            <span class="project-desc">Switch case — replaces if-else for cleaner structure</span>
            <span class="project-pins">P2.1 P2.2 → P1.0 P1.6</span>
        </div>
        <!-- 09 - Mixed -->
        <div class="project-row">
            <span class="project-num">09</span>
            <span class="badge badge-mixed">Mixed</span>
            <span class="project-desc">Mixed config — P2.1 pull-down, P2.2 floating</span>
            <span class="project-pins">P2.1 P2.2 → P1.0 P1.6</span>
        </div>
    </div>

    <!-- Key concepts covered -->
    <div class="keywords-section">
        <div class="keywords-title">⚙️ Key concepts covered</div>
        <div class="keywords-flex">
            <span class="keyword">P1DIR / P2DIR</span>
            <span class="keyword">P1OUT / P2OUT</span>
            <span class="keyword">P1IN / P2IN</span>
            <span class="keyword">P1REN pull-up/down</span>
            <span class="keyword">Bitwise OR |=</span>
            <span class="keyword">Bitwise AND &= ~</span>
            <span class="keyword">XOR toggle ^=</span>
            <span class="keyword">__delay_cycles()</span>
            <span class="keyword">Switch-case</span>
            <span class="keyword">Floating input fix</span>
        </div>
    </div>

    <!-- optional subtle footer (github friendly) -->
    <div class="footer-note">
        MSP430G2553 · GPIO fundamentals · TI LaunchPad ready
    </div>
</div>
</body>
</html>
